# ============================================================================
# FASTAPI ENVIRONMENT VARIABLES
# ============================================================================

# === REQUIRED ===

# Groq API Key (for AI features)
GROQ_API_KEY=your_groq_api_key_here

# YouTube API Key (for video search and info)
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Internal API Secret (shared with Express - MUST BE SAME)
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=your_32_character_secret_here_same_as_express

# === OPTIONAL ===

# Node Environment
NODE_ENV=development

# Frontend URLs (comma-separated)
FRONTEND_URL=http://localhost:8501,http://localhost:3000

# ============================================================================
# IMPORTANT NOTES
# ============================================================================

# 1. INTERNAL_API_SECRET must be EXACTLY THE SAME in both Express and FastAPI
# 2. Never commit this file with real values to git
# 3. Generate strong secrets using: openssl rand -hex 32
# 4. For production, use environment variable managers (AWS Secrets Manager, etc.)

# ============================================================================
# HOW TO GET API KEYS
# ============================================================================

# GROQ_API_KEY:
#   1. Go to https://console.groq.com
#   2. Sign up / Log in
#   3. Go to API Keys section
#   4. Create new API key
#   5. Copy and paste here

# YOUTUBE_API_KEY:
#   1. Go to https://console.cloud.google.com
#   2. Create new project (or select existing)
#   3. Enable "YouTube Data API v3"
#   4. Go to Credentials
#   5. Create API Key
#   6. Copy and paste here
#   7. (Optional) Restrict key to YouTube Data API v3 only

# INTERNAL_API_SECRET:
#   Generate with: openssl rand -hex 32
#   OR in Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   CRITICAL: Must be the SAME in Express .env file!
